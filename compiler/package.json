{
  "name": "imxc",
  "version": "0.5.1",
  "description": "Compiler for IMX — compiles React-like .tsx to native Dear ImGui C++",
  "type": "module",
  "bin": {
    "imxc": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["imgui", "react", "tsx", "native", "gui", "compiler", "codegen"],
  "license": "MIT",
  "dependencies": {
    "typescript": "^5.8.0"
  },
  "devDependencies": {
    "vitest": "^3.1.0",
    "@types/node": "^22.0.0"
  }
}
